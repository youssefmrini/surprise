# Copy to .env.local for local dev, then run: npx vercel dev
# (Never commit .env.local — it is gitignored.)
#
# In the browser, add ?debug=1 to the URL to see technical vote-API messages.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Admin dashboard (admin.html → GET /api/admin). Use a long random string; never commit it.
ADMIN_SECRET=change-me-min-12-chars-random
