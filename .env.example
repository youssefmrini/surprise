# Copy to .env.local for local dev, then run: npx vercel dev
# (Never commit .env.local — it is gitignored.)
#
# Primary DB (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#
# Admin page + /api/admin + POST /api/reveal (Edge middleware Basic Auth)
ADMIN_PASSWORD=choose-a-strong-secret
#
# Optional one-time migration source (old Supabase project)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
